rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Catch-all safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.1 Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function getUserData() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function hasRole(role) { return isSignedIn() && getUserData().role == role; }
    function isPrincipal() { return hasRole('principal') || hasRole('admin'); }
    function isAccountant() { return hasRole('accountant'); }
    function isTeacher() { return hasRole('teacher'); }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    // 1. Students Collection
    match /students/{studentId} {
      allow get: if isSignedIn() && (isPrincipal() || isTeacher() || isAccountant() || resource.data.email == request.auth.token.email);
      allow list: if isSignedIn() && (isPrincipal() || isTeacher() || isAccountant());
      allow create: if isPrincipal() && isValidStudent(request.resource.data);
      allow update: if isPrincipal() && isValidStudent(request.resource.data);
      allow delete: if isPrincipal();
    }

    // 2. Teachers Collection
    match /teachers/{teacherId} {
      allow read: if isSignedIn() && (isPrincipal() || isOwner(teacherId));
      allow write: if isPrincipal();
    }

    // 3. Transactions & Fees
    match /transactions/{tId} {
      allow read: if isSignedIn() && (isPrincipal() || isAccountant());
      allow write: if isSignedIn() && (isPrincipal() || isAccountant());
    }

    match /fees/{feeId} {
      allow read: if isSignedIn() && (isPrincipal() || isAccountant() || (hasRole('student') && resource.data.studentEmail == request.auth.token.email));
      allow write: if isSignedIn() && (isPrincipal() || isAccountant());
    }

    // Validation Helpers
    function isValidStudent(data) {
      return data.keys().hasAll(['id', 'name', 'rollNumber', 'email'])
             && data.name is string && data.name.size() <= 100
             && data.email is string && data.email.size() <= 100
             && data.rollNumber is string;
    }
  }
}
